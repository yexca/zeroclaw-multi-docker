# Copy this file to .env and fill in the values you use.

# Official ZeroClaw image. The Debian variant includes a shell and Matrix support,
# so bootstrap/render-config.sh can run without a local image build.
ZEROCLAW_IMAGE=ghcr.io/zeroclaw-labs/zeroclaw:v0.8.1-debian

# Each agent chooses its own model provider. Supported examples:
# - deepseek/text with chat_completions
# - openai/main with chat_completions
# - gemini/flash with native Gemini defaults
# - ollama/local for a host or LAN Ollama server

# Vision route: used when Matrix messages contain image markers.
VISION_API_KEY=
VISION_MODEL=gpt-4o
VISION_BASE_URL=https://api.openai.com/v1
VISION_WIRE_API=chat_completions
VISION_ALLOW_REMOTE_FETCH=false
VISION_MAX_IMAGES=4
VISION_MAX_IMAGE_SIZE_MB=5
VISION_MAX_IMAGE_TURNS=2

MATRIX_HOMESERVER=https://matrix.example.com
MATRIX_HOST_IP=
# Empty means allow all rooms. Use comma-separated room IDs to restrict.
MATRIX_ALLOWED_ROOMS=!roomid:matrix.example.com
MATRIX_MENTION_ONLY=false
MATRIX_INTERRUPT_ON_NEW_MESSAGE=true
MATRIX_REPLY_IN_THREAD=true
MATRIX_ACK_REACTIONS=true
MATRIX_STREAM_MODE=off
MATRIX_MULTI_MESSAGE=false
MATRIX_MULTI_MESSAGE_DELAY_MS=800
CHANNEL_DEBOUNCE_MS=3000

# Built-in ZeroClaw heartbeat. It reads /zeroclaw-data/.zeroclaw/data/HEARTBEAT.md.
HEARTBEAT_ENABLED=false
HEARTBEAT_INTERVAL_MINUTES=30
HEARTBEAT_TWO_PHASE=true
HEARTBEAT_MESSAGE=
HEARTBEAT_ADAPTIVE=false
HEARTBEAT_MIN_INTERVAL_MINUTES=5
HEARTBEAT_MAX_INTERVAL_MINUTES=120
HEARTBEAT_DEADMAN_TIMEOUT_MINUTES=0
HEARTBEAT_MAX_RUN_HISTORY=100
HEARTBEAT_LOAD_SESSION_CONTEXT=false
HEARTBEAT_TASK_TIMEOUT_SECS=600

# Agent loop detector. Comma-separated tools are ignored by loop detection.
PACING_LOOP_IGNORE_TOOLS=home__job_status
PACING_LOOP_DETECTION_ENABLED=true
PACING_LOOP_DETECTION_WINDOW_SIZE=20
PACING_LOOP_DETECTION_MAX_REPEATS=3

# Local shell execution timeouts for agent tools.
SHELL_TIMEOUT_SECS=300
SHELL_TOOL_TIMEOUT_SECS=300

AGENT1_HOST_PORT=42641
AGENT1_MODEL_PROVIDER_FAMILY=deepseek
AGENT1_MODEL_PROVIDER_ALIAS=text
AGENT1_MODEL=deepseek-chat
AGENT1_MODEL_BASE_URL=https://api.deepseek.com/v1
AGENT1_MODEL_API_KEY=
AGENT1_MODEL_WIRE_API=chat_completions
AGENT1_MODEL_TIMEOUT_SECS=120
AGENT1_MODEL_KIND=
AGENT1_MATRIX_USER_ID=@agent1:matrix.example.com
AGENT1_MATRIX_DEVICE_ID=ZEROCLAW_AGENT1
AGENT1_MATRIX_ACCESS_TOKEN=
AGENT1_MATRIX_PASSWORD=
AGENT1_MATRIX_RECOVERY_KEY=
AGENT1_MATRIX_EXTERNAL_PEERS=@you:matrix.example.com,#agent1-room:matrix.example.com
AGENT1_MCP_GATEWAY_TOKEN=

AGENT2_HOST_PORT=42642
AGENT2_MODEL_PROVIDER_FAMILY=ollama
AGENT2_MODEL_PROVIDER_ALIAS=local
AGENT2_MODEL=qwen2.5:14b
AGENT2_MODEL_BASE_URL=http://host.docker.internal:11434
AGENT2_MODEL_API_KEY=
AGENT2_MODEL_WIRE_API=chat_completions
AGENT2_MODEL_TIMEOUT_SECS=600
AGENT2_MODEL_KIND=
AGENT2_MATRIX_USER_ID=@agent2:matrix.example.com
AGENT2_MATRIX_DEVICE_ID=ZEROCLAW_AGENT2
AGENT2_MATRIX_ACCESS_TOKEN=
AGENT2_MATRIX_PASSWORD=
AGENT2_MATRIX_RECOVERY_KEY=
AGENT2_MATRIX_EXTERNAL_PEERS=@you:matrix.example.com,#agent2-room:matrix.example.com
AGENT2_MCP_GATEWAY_TOKEN=

AGENT3_HOST_PORT=42643
AGENT3_MODEL_PROVIDER_FAMILY=gemini
AGENT3_MODEL_PROVIDER_ALIAS=flash
AGENT3_MODEL=gemini-2.5-flash
AGENT3_MODEL_BASE_URL=
AGENT3_MODEL_API_KEY=
AGENT3_MODEL_WIRE_API=
AGENT3_MODEL_TIMEOUT_SECS=120
AGENT3_MODEL_KIND=
AGENT3_MATRIX_USER_ID=@agent3:matrix.example.com
AGENT3_MATRIX_DEVICE_ID=ZEROCLAW_AGENT3
AGENT3_MATRIX_ACCESS_TOKEN=
AGENT3_MATRIX_PASSWORD=
AGENT3_MATRIX_RECOVERY_KEY=
AGENT3_MATRIX_EXTERNAL_PEERS=@you:matrix.example.com,#agent3-room:matrix.example.com
AGENT3_MCP_GATEWAY_TOKEN=

# OpenAI chat-completions example for any agent:
# AGENT4_MODEL_PROVIDER_FAMILY=openai
# AGENT4_MODEL_PROVIDER_ALIAS=main
# AGENT4_MODEL=gpt-4o-mini
# AGENT4_MODEL_BASE_URL=https://api.openai.com/v1
# AGENT4_MODEL_API_KEY=sk-...
# AGENT4_MODEL_WIRE_API=chat_completions
# AGENT4_MODEL_TIMEOUT_SECS=120
# AGENT4_MODEL_KIND=

# Optional local MCP gateway exposed on the host.
MCP_ENABLED=false
MCP_SERVER_NAME=home
MCP_TRANSPORT=sse
MCP_URL=http://host.docker.internal:8787/mcp
MCP_DEFERRED_LOADING=false
MCP_TOOL_TIMEOUT_SECS=120
# Fallback token used only when AGENT*_MCP_GATEWAY_TOKEN is empty.
MCP_GATEWAY_TOKEN=

# Optional proactive sidecar. It POSTs to the local gateway /webhook.
PROACTIVE_IMAGE=python:3.12-alpine
PROACTIVE_ENABLED=false
PROACTIVE_AGENTS=agent1=http://agent1:42617/webhook,agent2=http://agent2:42617/webhook,agent3=http://agent3:42617/webhook
PROACTIVE_CHANNELS=agent1=matrix.home,agent2=matrix.home,agent3=matrix.home
PROACTIVE_TARGETS=agent1=#agent1-room:matrix.example.com,agent2=#agent2-room:matrix.example.com,agent3=#agent3-room:matrix.example.com
PROACTIVE_POLL_SECONDS=300
PROACTIVE_RANDOM_MIN_MINUTES=90
PROACTIVE_RANDOM_MAX_MINUTES=240
PROACTIVE_COOLDOWN_MINUTES=120
PROACTIVE_QUIET_HOURS=
PROACTIVE_TIMEZONE=Asia/Tokyo
PROACTIVE_PROMPT=You are being invoked by the proactive sidecar, not by the user. Review HEARTBEAT.md, memory, and current context. If there is a concrete, timely reason to contact the user, send one short Matrix message with send_message_to_peer using the configured channel and peer target. If there is no useful reason, respond exactly with "skip".
