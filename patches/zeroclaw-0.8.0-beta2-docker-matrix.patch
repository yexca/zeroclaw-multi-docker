+fn create_vision_model_provider(
+    provider_ref: &str,
+    root_config: Option<&zeroclaw_config::schema::Config>,
+) -> anyhow::Result<Box<dyn ModelProvider>> {
+    if let Some(config) = root_config
+        && let Some((family, alias)) = provider_ref.split_once('.')
+        && let Some(entry) = config.providers.models.find(family, alias)
+    {
+        let options = zeroclaw_providers::model_provider_runtime_options_from_model_provider_entry(
+            config,
+            Some(entry),
+        );
+        return zeroclaw_providers::create_model_provider_for_alias(
+            config,
+            family,
+            alias,
+            entry.api_key.as_deref(),
+            &options,
+        );
+    }
+
+    zeroclaw_providers::create_model_provider(provider_ref, None)
+}
