.env
__pycache__/
*.py[cod]
tmp/
manager/frontend/dist/
manager/frontend/node_modules/

# Local WebUI manager configuration. Commit only *.example.yaml files.
config/manager.yaml
config/secrets.yaml
config/manager.local.yaml
config/secrets.local.yaml
config/*.local.yaml
config/generated/*
!config/generated/.gitkeep

# Runtime state. Keep bootstrap/config logic tracked, but not Matrix sessions,
# crypto stores, memories, logs, or generated workspaces.
instances/*
!instances/.gitkeep
instances/*/.zeroclaw/state/
instances/*/.zeroclaw/daemon_state.json
instances/*/data/
instances/*/agents/
instances/*/shared/
instances/*/logs/
instances/*/backup-*/
instances/*/workspace/cron/
instances/*/workspace/memory/
instances/*/workspace/sessions/
instances/*/workspace/state/
instances/**/*.db
instances/**/*.db-*
instances/**/*.sock
instances/**/*.sqlite
instances/**/*.sqlite3
instances/**/*.jsonl
instances/**/matrix_files/
instances/**/store/
instances/**/*.png
instances/**/*.jpg
instances/**/*.jpeg
instances/**/*.webp

# Shared skill bundles are local/operator-authored by default.
shared/*
!shared/.gitkeep
